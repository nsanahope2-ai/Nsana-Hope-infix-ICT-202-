function infixToPostfix(expression):
    create empty stack
    result = ""

    for each character ch in expression:
        if ch is operand:
            add ch to result

        else if ch == '(':
            push ch to stack

        else if ch == ')':
            while top of stack != '(':
                pop and add to result
            pop '(' from stack

        else:
            while stack not empty AND precedence(top) >= precedence(ch):
                pop and add to result
            push ch to stack

    while stack not empty:
        pop and add to result

    return resultfunction infixToPrefix(expression):
    reverse expression

    for each character:
        if '(' replace with ')'
        if ')' replace with '('

    postfix = infixToPostfix(reversed expression)

    reverse postfix

    return prefix
